# Server-only (Vercel Environment Variables — NOT exposed to browser)
ADMIN_PASSWORD=your-secure-password
SESSION_SECRET=random-long-string

# Set automatically when you link Neon on Vercel (Storage → Neon → Connect):
# DATABASE_URL=postgresql://...   ← primary (pooled, recommended)
# DATABASE_URL_UNPOOLED=postgresql://...
# PGHOST=...
# Legacy Vercel Postgres may also set POSTGRES_URL

# Client: force API mode (optional; auto-detects when DB is available)
# VITE_USE_API=true

# Local-only admin password when using localStorage fallback
# VITE_ADMIN_PASSWORD=admin
